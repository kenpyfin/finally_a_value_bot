# Copy to .env beside index_vault.py / query_vault.py.
# VAULT_EMBEDDING_SERVER_URL is required (no default). Uncomment and set:
# VAULT_EMBEDDING_SERVER_URL=http://10.0.1.211:8080
# VAULT_VECTOR_DB_PATH=/path/to/workspace/shared/vault_db
# VAULT_ORIGIN_VAULT_PATH=shared/ORIGIN
# VAULT_VECTOR_DB_COLLECTION=origin_vault

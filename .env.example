# FinallyAValueBot — environment configuration
# Copy to .env and edit, or run: finally-a-value-bot config
#
# Meta (optional):
#   FINALLY_A_VALUE_BOT_CONFIG=/absolute/path/to/.env   # override default ./.env
#   FINALLY_A_VALUE_BOT_WORKSPACE_DIR=/path/to/workspace # overrides WORKSPACE_DIR after load

# -----------------------------------------------------------------------------
# Channels — at least one of Telegram or Discord is required
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
BOT_USERNAME=
AGENT_DISPLAY_NAME=

# DISCORD_BOT_TOKEN=          # use instead of/in addition to Telegram
# DISCORD_ALLOWED_CHANNELS=   # comma-separated numeric channel IDs; empty = all

# WhatsApp Cloud API (optional)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_WEBHOOK_PORT=8080

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------

LLM_PROVIDER=anthropic
LLM_API_KEY=
# LLM_MODEL=                 # empty = provider default (see config)
# LLM_BASE_URL=              # custom API base (OpenAI-compatible or provider-specific)

# Limits (defaults shown)
MAX_TOKENS=8192
MAX_TOOL_ITERATIONS=100
MAX_HISTORY_MESSAGES=50
MAX_DOCUMENT_SIZE_MB=100

# SHOW_THINKING=false        # surface model thinking blocks when supported

# -----------------------------------------------------------------------------
# Workspace and access control
# -----------------------------------------------------------------------------

WORKSPACE_DIR=./workspace
TIMEZONE=UTC

# ALLOWED_GROUPS=            # comma-separated Telegram group chat IDs; empty = all groups
# CONTROL_CHAT_IDS=          # comma-separated privileged chat IDs (cross-chat tools, etc.)
# UNIVERSAL_CHAT_ID=         # optional; several subsystems default to 997894126 when unset

# -----------------------------------------------------------------------------
# Web UI (default: enabled on localhost)
# -----------------------------------------------------------------------------

WEB_ENABLED=true
WEB_HOST=127.0.0.1
WEB_PORT=10961
# WEB_AUTH_TOKEN=            # required when WEB_HOST is not local (127.0.0.1 / localhost / ::1)
WEB_MAX_INFLIGHT_PER_SESSION=2
WEB_MAX_REQUESTS_PER_WINDOW=8
WEB_RATE_WINDOW_SECONDS=10
WEB_RUN_HISTORY_LIMIT=512
WEB_SESSION_IDLE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Scheduler (cron / one-shot tasks)
# -----------------------------------------------------------------------------

SCHEDULER_TASK_TIMEOUT_SECS=3600
SCHEDULER_STALE_RUNNING_RECLAIM_SECS=7200
SCHEDULER_MAX_CONCURRENT_TASKS=2
SCHEDULER_POLL_INTERVAL_SECS=60

# -----------------------------------------------------------------------------
# Agent stack (orchestrator, legacy TSA, PTE)
# -----------------------------------------------------------------------------

ORCHESTRATOR_ENABLED=true
# ORCHESTRATOR_MODEL=        # optional faster/cheaper model for planning

TOOL_SKILL_AGENT_ENABLED=false
# TOOL_SKILL_AGENT_MODEL=

POST_TOOL_EVALUATOR_ENABLED=false
# POST_TOOL_EVALUATOR_MODEL=

# -----------------------------------------------------------------------------
# Runtime reliability and workflow learning
# -----------------------------------------------------------------------------

RUNTIME_RELIABILITY_PROFILE=balanced
# balanced | aggressive_completion | safe_conservative

WORKFLOW_AUTO_LEARN=true
WORKFLOW_MIN_SUCCESS_REPETITIONS=2
WORKFLOW_REPLAY_STRICTNESS=adaptive
# strict | adaptive | loose

PROJECT_AUTO_ASSOCIATION_STRICTNESS=balanced
# strict | balanced | loose

# -----------------------------------------------------------------------------
# Cursor agent CLI (optional)
# -----------------------------------------------------------------------------

# CURSOR_AGENT_CLI_PATH=cursor-agent   # or cursor-agent.cmd on Windows if not on PATH
# CURSOR_AGENT_MODEL=
CURSOR_AGENT_TIMEOUT_SECS=1500
CURSOR_AGENT_TMUX_SESSION_PREFIX=finally_a_value_bot-cursor
CURSOR_AGENT_TMUX_ENABLED=true
# CURSOR_AGENT_RUNNER_URL=   # e.g. http://host:3847 — remote runner for cursor-agent

# -----------------------------------------------------------------------------
# Browser automation
# -----------------------------------------------------------------------------

# AGENT_BROWSER_PATH=        # full path to agent-browser if not on PATH (e.g. systemd/gateway)
BROWSER_MANAGED=false
# BROWSER_EXECUTABLE_PATH=
BROWSER_CDP_PORT_BASE=9222
# BROWSER_IDLE_TIMEOUT_SECS=
BROWSER_HEADLESS=false

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------

SAFETY_OUTPUT_GUARD_MODE=moderate
# off | moderate | strict

SAFETY_MAX_EMOJIS_PER_RESPONSE=12
SAFETY_TAIL_REPEAT_LIMIT=8
SAFETY_EXECUTION_MODE=warn_confirm
# off | warn_confirm | strict

SAFETY_RISKY_CATEGORIES=destructive,system,network,package

# -----------------------------------------------------------------------------
# Web search
# -----------------------------------------------------------------------------

# SEARXNG_URL=https://search.example.org
# When set, web_search uses SearXNG JSON API instead of DuckDuckGo HTML.

# -----------------------------------------------------------------------------
# Voice (optional — OpenAI Whisper transcription)
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# ORIGIN vault / vector search (optional) — uncomment and set to enable vault config
# Built-in skills (search-vault, index-vault) use scripts that read .env next to the script
# (e.g. workspace/skills/search-vault/.env). Set VAULT_EMBEDDING_SERVER_URL there (no default),
# or export it in the environment before running scripts.
# -----------------------------------------------------------------------------

# VAULT_ORIGIN_VAULT_PATH=shared/ORIGIN
# VAULT_VECTOR_DB_PATH=shared/vault_db
# VAULT_ORIGIN_VAULT_REPO=
# VAULT_GIT_URL=             # alias for VAULT_ORIGIN_VAULT_REPO
# VAULT_EMBEDDING_SERVER_URL=
# VAULT_SEARCH_COMMAND=
# VAULT_INDEX_COMMAND=
# VAULT_PRINCIPLES_PATH=
# VAULT_VECTOR_DB_URL=
# VAULT_VECTOR_DB_COLLECTION=vault

# -----------------------------------------------------------------------------
# Social integrations (optional) — uncomment any block you use
# -----------------------------------------------------------------------------

# SOCIAL_BASE_URL=
# SOCIAL_TIKTOK_CLIENT_ID=
# SOCIAL_TIKTOK_CLIENT_SECRET=
# SOCIAL_INSTAGRAM_CLIENT_ID=
# SOCIAL_INSTAGRAM_CLIENT_SECRET=
# SOCIAL_LINKEDIN_CLIENT_ID=
# SOCIAL_LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Git credentials (optional) — not read into Config; used by scripts/tooling (e.g. HTTPS git push)
# -----------------------------------------------------------------------------

# GIT_USERNAME=
# GIT_TOKEN=

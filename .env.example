# FinallyAValueBot configuration
# Copy to .env and edit, or run: finally-a-value-bot setup

# Telegram (required unless using Discord only)
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=

# LLM (anthropic, ollama, openai, openrouter, deepseek, google, etc.)
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=
# LLM_BASE_URL=

# Workspace
WORKSPACE_DIR=./workspace
TIMEZONE=UTC

# Orchestrator (plan-first architecture). Runs planning step before main agent loop.
# ORCHESTRATOR_ENABLED=true   # Orchestrator-first flow: plan then direct reply or delegate to sub-agents (default: true)
# ORCHESTRATOR_MODEL=         # Optional: faster/cheaper model for planning; if empty, use main model

# Tool and Skill Agent (TSA). Gates all tool/skill use before execution; denies direct writes under skills dir.
# TOOL_SKILL_AGENT_ENABLED=false   # Legacy: gate tool use when orchestrator disabled (default: false)
# TOOL_SKILL_AGENT_MODEL=          # Optional: faster model for TSA; if empty, use orchestrator or main model

# Post-Tool Evaluator (PTE). Evaluates task completion after each tool iteration; can short-circuit the loop.
# POST_TOOL_EVALUATOR_ENABLED=false  # Evaluate completion after tool results (default: false)
# POST_TOOL_EVALUATOR_MODEL=         # Optional: faster model for PTE; if empty, use orchestrator or main model

# Delegate tool. Allows the main agent to spawn focused sub-agents for independent tasks.
# DELEGATE_TOOL_ENABLED=true         # Enable the delegate tool (default: true)
# DELEGATE_MAX_ITERATIONS=10         # Max tool iterations per delegated sub-agent (default: 10)
# DELEGATE_MODEL=                    # Optional: model override for sub-agents; if empty, use main model

# Cursor Agent
# The Docker setup no longer supports a host runner by default.
# Use the cursor-agent skill for development tasks.
# CURSOR_AGENT_RUNNER_URL=

# Universal chat (optional). Single conversation across all channels (Telegram, Discord, web). Defaults to 997894126 when not set.
# UNIVERSAL_CHAT_ID=997894126

# Browser automation (optional). In Docker the image sets AGENT_BROWSER_PATH; leave unset for local (use PATH).
# AGENT_BROWSER_PATH=/usr/local/bin/agent-browser

# Web search: optional SearXNG instance. When set, web_search uses it instead of DuckDuckGo (avoids DDG blocks/empty results).
# Use your own instance or a public one; instance must allow format=json. Unset = DuckDuckGo HTML.
# SEARXNG_URL=https://search.example.org

# ORIGIN vault (optional). Paths relative to workspace_dir.
VAULT_ORIGIN_VAULT_PATH=shared/ORIGIN
VAULT_VECTOR_DB_PATH=shared/vault_db
# VAULT_ORIGIN_VAULT_REPO=https://github.com/you/ORIGIN.git

# Vault search and indexing: provided as built-in skills (search-vault, index-vault).
# The search_vault tool auto-detects the bundled query_vault.py script and Python venv.
# Just set VAULT_EMBEDDING_SERVER_URL and ensure the venv exists (run: bash skills/search-vault/setup_vault_env.sh).
# No need to set VAULT_SEARCH_COMMAND unless you want to override the auto-detected path.
# VAULT_SEARCH_COMMAND=  # Optional override; auto-detected from built-in skill if unset
# VAULT_INDEX_COMMAND=   # Optional override; index-vault skill provides the script
VAULT_EMBEDDING_SERVER_URL=http://127.0.0.1:8080
# Native mode (alternative): embedding server + ChromaDB HTTP API (requires ChromaDB server running).
# VAULT_VECTOR_DB_URL=http://localhost:8000
# VAULT_VECTOR_DB_COLLECTION=vault

# Git credentials for push inside container (optional). Enables git push from finally-a-value-bot/sync.
# Use GitHub username and a Personal Access Token (PAT) for HTTPS repos.
# GIT_USERNAME=
# GIT_TOKEN=

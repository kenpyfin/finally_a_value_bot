# Workspace: mount host ./workspace as /app/workspace; FINALLY_A_VALUE_BOT_WORKSPACE_DIR points there.
# Config: copy .env.example to .env and fill in values. Run: finally-a-value-bot setup
services:
  finally-a-value-bot:
    build: .
    container_name: finally-a-value-bot
    env_file: .env
    volumes:
      - ./.env:/app/.env:ro
      - ./workspace:/app/workspace
    environment:
      - FINALLY_A_VALUE_BOT_CONFIG=/app/.env
      - FINALLY_A_VALUE_BOT_WORKSPACE_DIR=/app/workspace
      - FINALLY_A_VALUE_BOT_IN_DOCKER=1
      - HOME=/root
    extra_hosts:
      - "host.docker.internal:host-gateway"
    ports:
      - "10961:10961"
    shm_size: "1gb"
    restart: unless-stopped
